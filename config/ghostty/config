# --- LOOK & FEEL ---
window-decoration = false
theme = "Aizen Dark"
font-family = "Monospace"
font-size = 11

# --- KEYBINDS ---
# 1. Alles markieren auf Ctrl+A (wie im Browser)
keybind = ctrl+a=select_all

# 2. Kopieren auf Ctrl+C (NUR wenn markiert, sonst Interrupt)
keybind = performable:ctrl+c=copy_to_clipboard

# 3. Einfügen auf Ctrl+V
keybind = ctrl+v=paste_from_clipboard
